+            // by any downstream tool, so skipping it is benign. Until the
+            // underlying vtable/thunk-table issue is solved, this lets WASM
+            // slicing complete with valid G-code output.
             std::string full_config;
             append_full_config(*m_print, full_config);
             if (!full_config.empty())
                 file.write(full_config);
+#endif
             file.write("; preflight_config = end\n");
         }
 
