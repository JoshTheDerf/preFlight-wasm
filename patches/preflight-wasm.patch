         // The delimiters are structured as configuration key / value pairs to be parsable by G-code viewers.
         {
             file.write("\n; preflight_config = begin\n");
+#ifndef __EMSCRIPTEN__
+            // WASM: skip the full-config dump. append_full_config() →
+            // encode_full_config() → cfg.keys() does a virtual dispatch on
+            // Print::m_full_print_config (a DynamicConfig). Under emscripten with
+            // -sEMULATE_FUNCTION_POINTER_CASTS=1 + -fexceptions, that dispatch
+            // resolves to function-table index 0 (a trap thunk) before entering the
+            // function body, surfacing as a "null function" trap. The config-
