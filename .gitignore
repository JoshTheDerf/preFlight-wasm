# --- bootstrapped toolchain & vendor source (scripts/setup.sh fetches all this) ---
# emsdk install (~1.6 GB), Boost source + install (~1.3 GB), portable cmake binary,
# ccache binary + cache, vendored single-header libs that setup.sh downloads.
#
# We ignore everything under deps/ but keep the build driver scripts in-tree,
# since they're repo-owned source even though the directories themselves are
# used as build & install prefixes. Each level must be un-ignored explicitly
# (git won't recurse into an ignored dir, so `deps/*` rather than `deps/`).
deps/*
!deps/boost-wasm
deps/boost-wasm/*
!deps/boost-wasm/build_boost.sh
!deps/toolchain-wasm
deps/toolchain-wasm/*
!deps/toolchain-wasm/build_math.sh
!deps/toolchain-wasm/README.md

# --- build output ---
# cmake build tree + linked artifacts (slicer.js / slicer.wasm / slicer.data,
# ~80 MB). The release workflow publishes these as GitHub release assets, not
# in-tree.
build-wasm/
build/
*.wasm
*.o
*.a
*.bc

# --- sample/test artifacts ---
*.gcode
*.gcode.bak

# --- preflight checkout (sibling tree, fetched separately for builds) ---
preflight/

# --- editor / OS noise ---
.DS_Store
*.swp
*.swo
*~
.vscode/
.idea/

# --- patch backups created by `git apply --reject` or manual edits ---
*.orig
*.rej
*.bak

# --- node-side scratch copies (the real test lives at tests/slice-test.cjs) ---
slicer.cjs
/slice-test.cjs
